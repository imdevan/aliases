# Function wrapper to auto-source aliases after running alias commands
# This ensures new/updated aliases are immediately available in your shell
{{if eq .Shell "fish" -}}
function {{.FunctionName}}
	if test (count $argv) -eq 0
		set -x CLICOLOR_FORCE 1
		set cmd (command aliases -i)
		if test -n "$cmd"
			eval $cmd
		end
	else
		command aliases $argv
	end
	source {{.FilePath}}
end
{{else if or (eq .Shell "nu") (eq .Shell "nushell") -}}
def --wrapped {{.FunctionName}} [...args] {
	if ($args | is-empty) {
		with-env {CLICOLOR_FORCE: "1"} {
			let cmd = (^aliases -i)
			if ($cmd | is-not-empty) {
				let parts = ($cmd | split row ';')
				for part in $parts {
					let trimmed = ($part | str trim)
					if ($trimmed | str starts-with "cd ") {
						let path = ($trimmed | str replace "cd " "" | str trim | str replace -r "^['\"]" "" | str replace -r "['\"]$" "")
						cd $path
					} else {
						nu -c $trimmed
					}
				}
			}
		}
	} else {
		^aliases ...$args
	}
}
{{else -}}
{{.FunctionName}}() {
	if [ $# -eq 0 ]; then
		local cmd=$(CLICOLOR_FORCE=1 command aliases -i)
		if [[ -n "$cmd" ]]; then
			eval "$cmd"
		fi
	else
		command aliases "$@"
	fi
	source {{.FilePath}}
}
{{end -}}
