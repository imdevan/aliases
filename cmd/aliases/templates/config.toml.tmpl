# Bookmark Manager Configuration

# General
# editor = {{printf "%q" .Editor}}

# CLI behavior
# interactive_default = {{.InteractiveDefault}}
# plain_text = false  # When true: output plain text confirmation messages and errors instead of styled output
# confirm_delete = {{.ConfirmDelete}}  # When false: delete bookmarks without confirmation prompt

# Bookmark settings
# bookmark_location = {{printf "%q" .BookmarkLocation}}  # Directory for bookmark files
# navigation_tool = {{printf "%q" .NavigationTool}}  # Options: cd, z, zoxide, none
# shell = {{printf "%q" .Shell}}  # Options: bash, zsh, fish, nu

# Auto-alias generation
# auto_alias_separator = {{printf "%q" .AutoAliasSeparator}}  # Character between first letters (empty = "", "-" = "m-c-p")
# auto_alias_lowercase = {{.AutoAliasLowercase}}
# default_alias_part_length = {{.DefaultAliasPartLength}}  # Number of characters to take from each part (1 = first letter only)

# Function alias wrapper
# When enabled, adds a shell function that auto-sources bookmarks after running bookmark commands
# Options: "true" (use default name "bookmark"), "custom_name" (use custom function name), "false" (disabled)
# function_alias = {{printf "%q" .FunctionAlias}}

# Interactive alias wrapper
# When enabled, adds a shell function for interactive bookmark navigation (bookmark -i)
# The function displays the TUI and executes the selected bookmark command
# Options: "bm" (default), "custom_name" (use custom function name), "false" (disabled)
# interactive_alias = {{printf "%q" .InteractiveAlias}}

# Display
# home_icon = {{printf "%q" .HomeIcon}}  # Icon to represent home directory in list view (can be nerd font icon like "")
# default_sort_by = {{printf "%q" .DefaultSortBy}}  # Options: newest, oldest, a-z, z-a

# UI
# list_spacing options: compact (title only), tight (title + description, no margin), space (default, with spacing)
# list_spacing = {{printf "%q" .ListSpacing}}

# Colors
# Colors support named, numeric, or hex values (ex: 7, 13, "#ff8800").
# headings = {{printf "%q" .Headings}}
# primary = {{printf "%q" .Primary}}
# secondary = {{printf "%q" .Secondary}}
# text = {{printf "%q" .Text}}
# text_highlight = {{printf "%q" .TextHighlight}}
# description_highlight = {{printf "%q" .DescriptionHighlight}}
# tags = {{printf "%q" .Tags}}
# flags = {{printf "%q" .Flags}}
# muted = {{printf "%q" .Muted}}
# border = {{printf "%q" .Border}}
# error = {{printf "%q" .Error}}
# success = {{printf "%q" .Success}}
